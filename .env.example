# Required for live Supabase mode
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Use your deployed site URL in production. Keep localhost for local development.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional, but required for one-click bootstrap in /setup
# Never expose this value to the browser or commit it to the repo.
SUPABASE_SERVICE_ROLE_KEY=
